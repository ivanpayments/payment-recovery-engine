    "original_transaction_id",
    "original_transaction_id_x",
    "original_transaction_id_y",
    "retry_attempt_num",
    "retry_reason",
    "hours_since_original",
    "psp_transaction_id",
    "psp_reference",
    "gateway_id",
    "network_transaction_id",
    "stan",
    "rrn",
    "arn",
    "captured_amount",
    "refunded_amount",
    "captured_at",
    "refunded_at",
    "voided_at",
    "settled_at",
    "merchant_id",
    "session_id",
    "correlation_id",
    "trace_id",
    "device_fingerprint",
    "bin_first6",
    "acquirer_bin",
    "terminal_id",
    "billing_zip",
    "billing_city",
    "billing_state",
    "subscription_id",
    "wallet_token",
    "merchant_descriptor",
    "dynamic_descriptor",
    "soft_descriptor",
    "issuer_bank_name",
    "issuer_bank_bin_range",
    "stored_credential_id",
    "has_any_retry",
    "retry_count",
    "first_retry_status",
    "first_retry_attempt_num",
    "hours_to_first_retry",
    "recovery_attempt_num",
    "hours_to_recovery",
    "target_recovered_by_retry",
    "target_first_retry_approved",
    "chargeback_reason_code"
  ],
  "review_before_final_use": [
    "is_chargeback",
    "is_recurring",
    "recurring_type",
    "installment_count",
    "installment_number",
    "partial_approval_flag",
    "stand_in_auth",
    "pin_verified",
    "signature_captured",
    "contactless",
    "nfc_used",
    "apple_pay",
    "google_pay",
    "samsung_pay",
    "click_to_pay",
    "is_mit",
    "mit_flag_revoked",
    "original_authorized_amount",
    "acquirer_country",
    "mcc_category"
  ],
  "notes": [
    "Only fields known at original decline time should be used for model training.",
    "Excluded fields may remain in the modeling table for traceability and reporting.",
    "Review-list features are not banned, but should be included only after confirming they do not leak generator logic or post-decision information."
  ]
}
