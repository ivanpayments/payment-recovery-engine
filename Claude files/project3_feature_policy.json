    "issuer_country",
    "payment_method",
    "wallet_type",
    "network_token_present",
    "entry_mode",
    "pan_entry_mode",
    "cardholder_verification_method",
    "cvv_result",
    "avs_result",
    "avs_zip_match",
    "avs_street_match",
    "payment_method_details",
    "issuer_bank_country",
    "card_product_type",
    "card_category",
    "card_commercial_type",
    "user_agent_family",
    "timeout_flag",
    "device_os",
    "issuer_size",
    "account_updater_used",
    "mastercard_advice_code",
    "routing_optimized",
    "mcc_routing_optimized",
    "smart_routed",
    "scheme_ms",
    "transaction_type",
    "fx_bps",
    "routed_network",
